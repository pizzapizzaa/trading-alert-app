# Copy this file to .env and fill in your values before starting the admin server.

# Required: secret token the web dashboard must send as "Authorization: Bearer <token>"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_SECRET=change-me-to-a-long-random-secret

# Optional: restrict CORS to your web dashboard domain (defaults to localhost:3001)
# CORS_ORIGIN=https://your-web-dashboard.vercel.app

# Optional: override port (default: 3001)
# PORT=3001
